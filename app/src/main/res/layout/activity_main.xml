<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F6"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B5E3B"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A7C4A0"
                android:textSize="12sp"
                android:letterSpacing="0.04" />

            <TextView
                android:id="@+id/tvTodayEarnings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S$0.00"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:paddingTop="2dp" />

            <TextView
                android:id="@+id/tvTripCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No trips today"
                android:textColor="#A7C4A0"
                android:textSize="12sp"
                android:paddingTop="2dp" />

            <TextView
                android:id="@+id/tvSyncStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not signed in"
                android:textColor="#A7C4A0"
                android:textSize="11sp"
                android:paddingTop="2dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnStartOverlay"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Start Overlay"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#2D6A4F"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Hint bar -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Overlay running - switch to Grab and tap the green button to start a trip"
        android:textColor="#2D6A4F"
        android:textSize="12sp"
        android:background="#E8F5E9"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone" />

    <!-- v4.0-alpha: Accessibility Service setup banner - tappable, opens SetupActivity -->
    <TextView
        android:id="@+id/bannerAS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Accessibility Service for auto fare capture - tap here to set up"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:background="#B45309"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <!-- Trip list label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TRIP HISTORY"
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/tvTapHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to edit"
            android:textColor="#9CA3AF"
            android:textSize="11sp" />
    </LinearLayout>


    <!-- v4.1-alpha: Trip history filter bar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnFilterDay"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Today"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#1B5E3B"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnFilterWeek"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="This Week"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#9CA3AF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnFilterMonth"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="This Month"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#9CA3AF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnFilterYear"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="This Year"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#9CA3AF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="All"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#9CA3AF"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Trip list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/tripListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp" />
    </ScrollView>

    <!-- Bottom bar - 4 buttons including Add Trip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1B5E3B"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnAddTrip"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="+ Add"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:background="#2D6A4F"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnExportCsv"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Export"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:background="#2D6A4F"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnSyncStore"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Sync"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#2D6A4F"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="More"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="#2D6A4F"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
